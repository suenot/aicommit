# Example GitHub Actions workflow for AI Commit Message Analysis
# Copy this file to your repository as .github/workflows/ai-commit-analyzer.yml
# and configure it with your OpenRouter API key

name: AI Commit Analyzer

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main ]

jobs:
  analyze-commits:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0  # Fetch full history for commit comparison

      - name: Analyze commits with AI
        uses: suenot/aicommit@main
        with:
          openrouter_api_key: ${{ secrets.OPENROUTER_API_KEY }}
          mode: 'suggest'  # 'analyze' for report only, 'suggest' for improvement suggestions
          verbose: 'false'

      # Optional: Post suggestions as a PR comment
      - name: Post analysis to PR
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const suggestions = '${{ steps.analyze.outputs.suggestions }}';
            if (suggestions) {
              const parsed = JSON.parse(suggestions);
              const improvements = parsed.filter(s => s.differs);

              if (improvements.length > 0) {
                let body = '## AI Commit Message Analysis\n\n';
                body += 'The following commits could have improved messages:\n\n';

                for (const s of improvements) {
                  body += `### Commit \`${s.short_sha}\`\n`;
                  body += `- **Original:** ${s.original_message}\n`;
                  body += `- **Suggested:** ${s.suggested_message}\n\n`;
                }

                await github.rest.issues.createComment({
                  issue_number: context.issue.number,
                  owner: context.repo.owner,
                  repo: context.repo.repo,
                  body: body
                });
              }
            }
