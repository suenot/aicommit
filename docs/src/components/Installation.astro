.087l.414 1.1066a.3452.3452 0 00.5781.1154l.8079-.8656c.0972.0111.1954.0203.2936.0294l.6236 1.0073a.3472.3472 0 00.5892 0l.6236-1.0073c.0982-.0091.1964-.0183.2936-.0294l.8069.8656a.3483.3483 0 00.578-.1154l.4141-1.1066a8.4626 8.4626 0 00.2855-.087l.9587.6904a.3452.3452 0 00.5447-.2268l.1903-1.1662c.088-.0456.1751-.0931.2622-.1407l1.0762.49a.3472.3472 0 00.49-.327l-.0415-1.1845a6.7267 6.7267 0 00.2267-.1863l1.1531.2713a.3472.3472 0 00.4171-.416l-.2713-1.1542c.0628-.0749.1255-.1508.1863-.2278l1.1845.0415a.3442.3442 0 00.328-.49l-.49-1.076c.0475-.0872.0951-.1742.1407-.2623l1.1662-.1893a.3483.3483 0 00.2258-.5447l-.6904-.9587.087-.2855 1.1066-.414a.3462.3462 0 00.1154-.5781l-.8656-.8079c.0101-.0972.0202-.1954.0283-.2936l1.0073-.6236a.3442.3442 0 000-.5892zm-6.7413 8.3551a.7138.7138 0 01.2986-1.396.714.714 0 11-.2997 1.396zm-.3422-2.3142a.649.649 0 00-.7715.5l-.3573 1.6685c-1.1035.501-2.3285.7795-3.6193.7795a8.7368 8.7368 0 01-3.6951-.814l-.3574-1.6684a.648.648 0 00-.7714-.499l-1.473.3158a8.7216 8.7216 0 01-.7613-.898h7.1676c.081 0 .1356-.0141.1356-.088v-2.536c0-.074-.0536-.0881-.1356-.0881h-2.0966v-1.6077h2.2677c.2065 0 1.1065.0587 1.394 1.2088.0901.3533.2875 1.5044.4232 1.8729.1346.413.6833 1.2381 1.2685 1.2381h3.5716a.7492.7492 0 00.1296-.0131 8.7874 8.7874 0 01-.8119.9526zM6.8369 20.024a.714.714 0 11-.2997-1.396.714.714 0 01.2997 1.396zM4.1177 8.9972a.7137.7137 0 11-1.304.5791.7137.7137 0 011.304-.579zm-.8352 1.9813l1.5347-.6824a.65.65 0 00.33-.8585l-.3158-.7147h1.2432v5.6025H3.5669a8.7753 8.7753 0 01-.2834-3.348zm6.7343-.5437V8.7836h2.9601c.153 0 1.0792.1772 1.0792.8697 0 .575-.7107.7815-1.2948.7815zm10.7574 1.4862c0 .2187-.008.4363-.0243.651h-.9c-.09 0-.1265.0586-.1265.1477v.413c0 .973-.5487 1.1846-1.0296 1.2382-.4576.0517-.9648-.1913-1.0275-.4717-.2704-1.5186-.7198-1.8436-1.4305-2.4034.8817-.5599 1.799-1.386 1.799-2.4915 0-1.1936-.819-1.9458-1.3769-2.3153-.7825-.5163-1.6491-.6195-1.883-.6195H5.4682a8.7651 8.7651 0 014.907-2.7699l1.0974 1.151a.648.648 0 00.9182.0213l1.227-1.1743a8.7753 8.7753 0 016.0044 4.2762l-.8403 1.8982a.652.652 0 00.33.8585l1.6178.7188c.0283.2875.0425.577.0425.8717zm-9.3006-9.5993a.7128.7128 0 11.984 1.0316.7137.7137 0 01-.984-1.0316zm8.3389 6.71a.7107.7107 0 01.9395-.3625.7137.7137 0 11-.9405.3635z"/></svg>
					</div>
					<span class="speed fast">Primary / Recommended</span>
				</div>
				<h3>Cargo / Rust</h3>
				<p>Best for Rust developers and users who want absolute maximum performance.</p>
				<div class="code-block">
					<pre><code>cargo install aicommit</code></pre>
				</div>
			</div>

			<div class="install-card">
				<div class="card-glow"></div>
				<div class="card-header">
					<div class="icon npm" style="padding: 6px;">
						<svg role="img" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><title>npm</title><path d="M1.763 0C.786 0 0 .786 0 1.763v20.474C0 23.214.786 24 1.763 24h20.474c.977 0 1.763-.786 1.763-1.763V1.763C24 .786 23.214 0 22.237 0zM5.13 5.323l13.837.019-.009 13.836h-3.464l.01-10.382h-3.456L12.04 19.17H5.113z"/></svg>
					</div>
					<span class="speed normal">Also Available</span>
				</div>
				<h3>NPM / Node.js</h3>
				<p>For global CLI access from any project. Perfect for JS/TS environments.</p>
				<div class="code-block">
					<pre><code>npm install -g @suenot/aicommit</code></pre>
				</div>
			</div>

			<div class="install-card">
				<div class="card-glow"></div>
				<div class="card-header">
					<div class="icon source">
						<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"></polyline></svg>
					</div>
					<span class="speed new">Latest</span>
				</div>
				<h3>Build from Source</h3>
				<p>Clone the repository and build the binary yourself for experimental features.</p>
				<div class="code-block">
					<pre><code>git clone https://github.com/suenot/aicommit
cd aicommit
cargo install --path .</code></pre>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.installation {
		padding: 10rem 0;
		background: #0b1120;
		position: relative;
		overflow: hidden;
	}
	.background-accents {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		pointer-events: none;
	}
	.line {
		position: absolute;
		height: 1px;
		background: linear-gradient(to right, transparent, rgba(79, 70, 229, 0.2), transparent);
		width: 100%;
	}
	.line-1 { top: 20%; transform: rotate(-5deg); }
	.line-2 { bottom: 20%; transform: rotate(5deg); }

	.header {
		text-align: center;
		margin-bottom: 6rem;
	}
	.eyebrow {
		color: rgb(var(--accent-light));
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.875rem;
		margin-bottom: 1rem;
		display: block;
	}
	h2 {
		font-size: 4rem;
		font-weight: 800;
		margin-bottom: 1.5rem;
		letter-spacing: -0.04em;
	}
	.header p {
		font-size: 1.25rem;
		color: #94a3b8;
		max-width: 600px;
		margin: 0 auto;
	}

	.install-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
		gap: 3rem;
	}
	.install-card {
		padding: 3.5rem;
		background: rgba(30, 41, 59, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.05);
		border-radius: 2.5rem;
		position: relative;
		overflow: hidden;
		transition: all 0.4s ease;
	}
	.install-card.prominent {
		border-color: rgba(79, 70, 229, 0.5);
		background: rgba(79, 70, 229, 0.05);
	}
	.install-card:hover {
		transform: translateY(-10px) scale(1.02);
		border-color: rgba(79, 70, 229, 0.3);
		background: rgba(30, 41, 59, 0.6);
	}
	.card-glow {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 150px;
		background: radial-gradient(circle at 50% 0%, rgba(79, 70, 229, 0.15) 0%, transparent 70%);
		opacity: 0;
		transition: opacity 0.4s ease;
	}
	.install-card:hover .card-glow {
		opacity: 1;
	}
	.install-card.prominent .card-glow {
		opacity: 0.5;
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}
	.icon {
		width: 48px;
		height: 48px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.05);
		color: white;
	}
	.icon.npm { color: #CB3837; }
	.icon.cargo { color: #F46623; }
	.icon.source { color: #38bdf8; }
	
	.speed {
		font-size: 0.75rem;
		padding: 0.35rem 0.85rem;
		border-radius: 9999px;
		font-weight: 700;
		text-transform: uppercase;
	}
	.speed.fast { background: rgba(34, 197, 94, 0.1); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.2); }
	.speed.normal { background: rgba(255, 255, 255, 0.05); color: #94a3b8; border: 1px solid rgba(255, 255, 255, 0.1); }
	.speed.new { background: rgba(56, 189, 248, 0.1); color: #38bdf8; border: 1px solid rgba(56, 189, 248, 0.2); }

	h3 {
		font-size: 1.75rem;
		font-weight: 700;
		margin-bottom: 1rem;
		color: #f8fafc;
	}
	.install-card p {
		color: #94a3b8;
		margin-bottom: 2.5rem;
		font-size: 1.1rem;
		line-height: 1.6;
	}

	.code-block {
		background: #020617;
		padding: 1.5rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.05);
		position: relative;
	}
	pre {
		margin: 0;
		overflow-x: auto;
		scrollbar-width: none;
	}
	pre::-webkit-scrollbar { display: none; }
	
	pre code {
		color: #e2e8f0;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.95rem;
	}
</style>
