---
---

<section id="installation" class="installation">
	<div class="background-accents">
		<div class="line line-1"></div>
		<div class="line line-2"></div>
	</div>

	<div class="container">
		<div class="header">
			<span class="eyebrow">Deployment</span>
			<h2>Ready to Start?</h2>
			<p>Get AICommit running in seconds with your preferred package manager. <br/><strong>Cargo is recommended for best performance.</strong></p>
		</div>
		<div class="install-grid">
			<div class="install-card prominent">
				<div class="card-glow"></div>
				<div class="card-header">
					<div class="icon cargo" style="color: white; padding: 6px;">
